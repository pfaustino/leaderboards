# Turso (required in Vercel project env)
TURSO_DATABASE_URL=libsql://your-db-name-username.turso.io
TURSO_AUTH_TOKEN=your-read-write-token

# Optional JSON map of game id → write secret (POST /api/score)
# If omitted, writes are rejected in production.
WRITE_KEYS={"gigazonk":"change-me","calamari-damacy":"change-me-too"}
